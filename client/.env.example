# Optional: override Railway API in dev (default: production Railway)
# VITE_API_PROXY=http://localhost:5000

# Companion server for seller orders, payouts, images, support, audit (MongoDB)
# Dev: Vite proxies to this URL automatically — run `npm run server` from repo root.
VITE_CHAT_PROXY=http://localhost:5000

# Production (Vercel): URL of deployed companion server (same routes as server/server.js)
# VITE_MIRROR_API_URL=https://your-mirror-server.up.railway.app
#
# Paymob keys go on the companion server (server/.env), not the React app:
# PAYMOB_API_KEY, PAYMOB_INTEGRATION_ID, PAYMOB_IFRAME_ID

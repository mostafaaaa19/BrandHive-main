{
  "name": "brandhive",
  "version": "1.0.0",
  "description": "BrandHive - Egypt's #1 Local Brand Marketplace",
  "private": true,
  "scripts": {
    "dev": "cd client && npm run dev",
    "server": "cd server && npm run dev",
    "dev:all": "concurrently -n server,client -c blue,green \"npm run server\" \"npm run dev\"",
    "deploy:mirror": "powershell -ExecutionPolicy Bypass -File scripts/deploy-mirror-railway.ps1",
    "cleanup:test-products": "node scripts/cleanup-test-products.mjs",
    "cleanup:test-products:execute": "node scripts/cleanup-test-products.mjs --execute",
    "build": "cd client && npm run build",
    "install:all": "cd client && npm install && cd ../server && npm install",
    "start": "cd server && npm start"
  },
  "keywords": [
    "marketplace",
    "egypt",
    "local-brands",
    "ecommerce"
  ],
  "dependencies": {
    "mongoose": "^9.6.3"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
